# Kopieer naar .env en vul aan
SECRET_KEY=vervang-door-lange-random-string
DATABASE_URL=postgresql://ravot:ravot@db:5432/ravot
SITE_URL=https://ravot.be

# UiTdatabank Search API — key via platform.publiq.be
# test:      https://search-test.uitdatabank.be
# productie: https://search.uitdatabank.be
UIT_SEARCH_URL=https://search-test.uitdatabank.be
UIT_API_KEY=

# Extra bronnen (optioneel). Aan/uit zet je in /beheer/instellingen.
# Ticketmaster Discovery API — gratis key via developer.ticketmaster.com
# (Ravot haalt hier ENKEL het Family-segment op, landcode BE.)
TICKETMASTER_API_KEY=
# Toerisme Vlaanderen (attracties) en OpenStreetMap (speeltuinen) vragen geen key.
# TOERISME_URL=https://linked.toerismevlaanderen.be
# OVERPASS_URL=https://overpass-api.de/api/interpreter

# Mail (SMTP). Leeg laten = console-mailer (dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Ravot <hallo@ravot.be>
